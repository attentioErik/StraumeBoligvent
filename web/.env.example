# Sanity CMS — kopier til .env.local og fyll inn verdiene
# Prosjekt-ID finnes på sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=din_project_id

# Dataset (vanligvis "production")
NEXT_PUBLIC_SANITY_DATASET=production

# API-versjon (endre kun ved behov)
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# URL til Sanity Studio (brukes for preview-lenker)
NEXT_PUBLIC_SANITY_STUDIO_URL=https://straume-boligvent.sanity.studio

# Kontaktskjema — legg til epostleverandør (valgfritt)
# Resend: https://resend.com
# RESEND_API_KEY=re_xxxx
# CONTACT_EMAIL=service@straumetekniske.no

# SMTP (alternativ til Resend)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=passord
